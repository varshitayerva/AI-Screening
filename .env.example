# ============================================
# Hugging Face API Configuration
# ============================================
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_API_BASE_URL=https://api-inference.huggingface.co/models

# Hugging Face Model IDs (Inference API Compatible - ALL VERIFIED)
HF_MODEL_EXTRACTION=mistralai/Mistral-7B-Instruct-v0.2
HF_MODEL_INTERVIEW=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_SUMMARY=meta-llama/Llama-3-8B-Instruct

# ============================================
# Server Configuration
# ============================================
BACKEND_PORT=8080
FRONTEND_PORT=4200
SERVER_SERVLET_CONTEXT_PATH=/

# ============================================
# Session Management
# ============================================
SESSION_TIMEOUT_HOURS=24
MAX_CONCURRENT_SESSIONS=100
SESSION_CLEANUP_INTERVAL_HOURS=1

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=pdf,txt,doc,docx
UPLOAD_TEMP_DIR=./temp-uploads

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_FILE_SIZE=10MB
LOG_MAX_BACKUP_INDEX=10

# ============================================
# AI Configuration
# ============================================
AI_CALL_TIMEOUT_SECONDS=30
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_DELAY_MS=1000
AI_TEMPERATURE=0.3
AI_MAX_TOKENS_EXTRACTION=1500
AI_MAX_TOKENS_INTERVIEW=2000
AI_MAX_TOKENS_SUMMARY=1500

# ============================================
# Security Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000
ENABLE_HTTPS=false
HTTPS_PORT=8443

# ============================================
# Database Configuration (Not Used - In-Memory)
# ============================================
# Spring Boot will use in-memory session storage
# No persistence layer required

# ============================================
# Environment Profile
# ============================================
SPRING_PROFILES_ACTIVE=dev
# Options: dev, test, prod

# ============================================
# Feature Flags
# ============================================
FEATURE_PDF_EXPORT=true
FEATURE_EMAIL_REPORTS=false
FEATURE_BATCH_PROCESSING=false

# ============================================
# Monitoring & Analytics (Optional)
# ============================================
ENABLE_METRICS=true
ENABLE_SWAGGER=true
SWAGGER_BASE_PATH=/api/v1
